{
  "name": "ziptune",
  "productName": "ZipTune",
  "version": "1.0.0",
  "description": "A simple cross-platform audio player that also plays audio from zip archives.",
  "main": "main.js",
  "homepage": "https://github.com/ziptune/ziptune",
  "author": {
    "name": "ZipTune",
    "email": "ziptune@example.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "icons": "node build-icons.js",
    "dist": "npm run icons && electron-builder",
    "dist:mac": "npm run icons && electron-builder --mac",
    "dist:win": "npm run icons && electron-builder --win",
    "dist:linux": "npm run icons && electron-builder --linux"
  },
  "dependencies": {
    "music-metadata": "^10.6.0",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png2icons": "^2.0.1",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.ziptune.app",
    "productName": "ZipTune",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/icon.*",
      "node_modules/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "AudioVideo",
      "maintainer": "ZipTune <ziptune@example.com>",
      "target": ["AppImage", "deb"]
    }
  }
}
